# Copy this file to .env and fill in your API keys

# Ollama Cloud (default provider) — https://ollama.com
OLLAMA_API_KEY=ollama_...

# OpenAI
OPENAI_API_KEY=sk-...

# Groq (fast, free tier available)
GROQ_API_KEY=gsk_...

# OpenRouter (aggregator: Claude, Gemini, Llama, ecc.)
OPENROUTER_API_KEY=sk-or-...

# Optional overrides
# OLLAMA_CODE_MODEL=llama3.3:70b
# OLLAMA_CODE_BASE_URL=https://api.ollama.com/v1
